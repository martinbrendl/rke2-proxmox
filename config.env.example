# ============================================================
#  rke2-proxmox — Local Configuration
# ============================================================
#
#  Copy this file to `config.env` and edit with your real values.
#  `config.env` is gitignored, so your secrets won't be committed.
#
#  Scripts source this file automatically if it exists next to
#  the script, one directory up, or in $HOME on the admin node.
#
#  Usage:
#    cp config.env.example config.env
#    vim config.env                         # edit with your values
#    scp config.env 1-cluster/rke2.sh ubuntu@10.0.0.210:~/
#    ssh ubuntu@10.0.0.210 'bash rke2.sh'
#
# ============================================================

# ---- Node IP addresses ----
admin=10.0.0.210
master1=10.0.0.211
master2=10.0.0.212
master3=10.0.0.213
worker1=10.0.0.214
worker2=10.0.0.215

# ---- SSH ----
user=ubuntu
certName=id_ed25519

# ---- Kube-VIP (HA virtual IP for control plane) ----
vip=10.0.0.220

# ---- LoadBalancer IP pool ----
# 1-cluster (MetalLB)
lbrange=10.0.0.221-10.0.0.230
# 2-cluster and above (Cilium LB-IPAM)
lbrangeStart=10.0.0.221
lbrangeStop=10.0.0.230

# ---- Rancher ----
rancherHostname=rancher.example.com
letsencryptEmail=you@example.com

# ---- Longhorn ----
longhorn_disk=/dev/sdb
longhorn_path=/var/lib/longhorn
longhorn_version=1.7.2

# ---- Addons (3-cluster and 4-cluster) ----
grafanaAdminPassword=admin
forgejoAdminUsername=forgejo-admin
forgejoAdminPassword=changeme
